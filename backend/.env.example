# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Anthropic API Key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# JWT Configuration - CHANGE THIS IN PRODUCTION!
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Database Configuration
# For development: sqlite:///./data.db
# For production (PostgreSQL): postgresql://user:password@localhost:5432/dbname
# For production (MySQL): mysql+pymysql://user:password@localhost:3306/dbname
DATABASE_URL=sqlite:///./data.db

# Environment
ENVIRONMENT=development
DEBUG=false

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Optional: OpenAI API Key (if using GPT models)
OPENAI_API_KEY=sk-your-key-here

# Optional: Redis/Celery configuration
REDIS_URL=redis://localhost:6379/0

# File paths
JOBS_DATA_DIR=./jobs_data
